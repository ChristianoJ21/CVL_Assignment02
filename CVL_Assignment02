{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":15791305,"datasetId":10122028,"databundleVersionId":16737655}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import sys\nimport os\nimport math\n\n# --- Pillow for I/O ---\ntry:\n    from PIL import Image\nexcept ImportError:\n    import os\n    os.system('pip install Pillow')\n    from PIL import Image\n\n# ==================================================================\n#  SECTION 1 — IMAGE LOADING & PRE-PROCESSING\n# ==================================================================\n\ndef load_image_as_pixels(path: str):\n    img = Image.open(path).convert(\"RGB\")\n    w, h = img.size\n    if w > 400:\n        ratio = 400 / w\n        img = img.resize((400, int(h * ratio)))\n        w, h = img.size\n    raw = list(img.getdata())\n    pixels = [raw[y * w:(y + 1) * w] for y in range(h)]\n    return pixels, w, h\n\ndef simple_blur(gray, w, h):\n    # Fixed: Now handles edges so the corners aren't zeroed out\n    out = [row[:] for row in gray] \n    for y in range(1, h-1):\n        for x in range(1, w-1):\n            avg = (gray[y-1][x-1] + gray[y-1][x] + gray[y-1][x+1] +\n                   gray[y][x-1]   + gray[y][x]   + gray[y][x+1] +\n                   gray[y+1][x-1] + gray[y+1][x] + gray[y+1][x+1]) // 9\n            out[y][x] = avg\n    return out\n\ndef save_pixels_as_image(pixels_2d, w: int, h: int, path: str):\n    flat = []\n    for row in pixels_2d:\n        flat.extend(row)\n    img = Image.new(\"RGB\", (w, h))\n    img.putdata(flat)\n    img.save(path)\n\n# ==================================================================\n#  SECTION 2 — CV LOGIC\n# ==================================================================\n\ndef rgb_to_grayscale(pixels, w, h):\n    return [[int(0.299*r + 0.587*g + 0.114*b) for (r, g, b) in row] for row in pixels]\n\ndef otsu_threshold(gray, w, h):\n    hist = [0] * 256\n    for row in gray:\n        for v in row: hist[v] += 1\n    total = w * h\n    sum_total = sum(i * hist[i] for i in range(256))\n    sum_bg = weight_bg = best_thresh = 0\n    best_var = -1.0\n    for t in range(256):\n        weight_bg += hist[t]\n        if weight_bg == 0: continue\n        weight_fg = total - weight_bg\n        if weight_fg == 0: break\n        sum_bg += t * hist[t]\n        mean_bg, mean_fg = sum_bg / weight_bg, (sum_total - sum_bg) / weight_fg\n        var_between = weight_bg * weight_fg * (mean_bg - mean_fg) ** 2\n        if var_between > best_var:\n            best_var, best_thresh = var_between, t\n    return best_thresh\n\ndef morphology(binary, w, h, op='dilate', k_size=3):\n    # Reduced k_size to 3 to prevent \"deleting\" the object during Erosion\n    k = k_size // 2\n    out = [[0] * w for _ in range(h)]\n    for y in range(h):\n        for x in range(w):\n            val = binary[y][x]\n            found = False\n            # Check neighborhood\n            for dy in range(-k, k+1):\n                for dx in range(-k, k+1):\n                    iy, ix = y + dy, x + dx\n                    if 0 <= iy < h and 0 <= ix < w:\n                        if op == 'dilate' and binary[iy][ix] == 1:\n                            val = 1\n                            found = True\n                            break\n                        if op == 'erode' and binary[iy][ix] == 0:\n                            val = 0\n                            found = True\n                            break\n                if found: break\n            out[y][x] = val\n    return out\n\n# ==================================================================\n#  SECTION 3 — EVALUATION\n# ==================================================================\n\ndef compute_metrics(pred, gt, w, h):\n    intersection = union = correct = 0\n    for y in range(h):\n        for x in range(w):\n            p, g = pred[y][x], gt[y][x]\n            if p == g: correct += 1\n            if p == 1 or g == 1: union += 1\n            if p == 1 and g == 1: intersection += 1\n    iou = intersection / union if union > 0 else 0.0\n    acc = correct / (w * h)\n    return iou, acc\n\n# ==================================================================\n#  SECTION 4 — EXECUTION\n# ==================================================================\n\ndef generate_demo_data(w=320, h=240):\n    # Using specific high-contrast values to guarantee accuracy\n    pixels = [[(220, 220, 220) for _ in range(w)] for _ in range(h)]\n    gt_mask = [[0] * w for _ in range(h)]\n    cx, cy, r = w//2, h//2, 50\n    for y in range(h):\n        for x in range(w):\n            if ((x-cx)**2 + (y-cy)**2) < r**2:\n                pixels[y][x] = (30, 30, 30) \n                gt_mask[y][x] = 1\n    return pixels, gt_mask, w, h\n\n# --- Configuration ---\nMODE = \"DEMO\"  # Set to \"REAL\" for your photo\nMY_PHOTO_PATH = \"/kaggle/input/datasets/christianojoseintoro/my-laundry-jpg/my_laundry.jpeg\"\nOUTPUT_DIR = \"output\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\nif MODE == \"DEMO\":\n    pixels, gt_mask, width, height = generate_demo_data()\nelse:\n    pixels, width, height = load_image_as_pixels(MY_PHOTO_PATH)\n    gt_mask = None \n\n# --- Processing Pipeline ---\ngray = rgb_to_grayscale(pixels, width, height)\nblurred = simple_blur(gray, width, height)\nt_val = otsu_threshold(blurred, width, height)\n\n# Determine Polarity (Is the object darker or lighter than background?)\n# We sample 4 corners to be sure\ncorners = [blurred[0][0], blurred[0][width-1], blurred[height-1][0], blurred[height-1][width-1]]\navg_corner = sum(corners) / 4\n\nif avg_corner > t_val: # Background is bright, Object is dark\n    binary = [[(1 if blurred[y][x] < t_val else 0) for x in range(width)] for y in range(height)]\nelse: # Background is dark, Object is bright\n    binary = [[(1 if blurred[y][x] > t_val else 0) for x in range(width)] for y in range(height)]\n\n# Perform a \"Closing\" operation (Dilate then Erode) to fill holes without shrinking too much\nmask_dilated = morphology(binary, width, height, 'dilate', k_size=3)\nfinal_mask = morphology(mask_dilated, width, height, 'erode', k_size=3)\n\n# --- Results ---\nprint(\"-\" * 40)\nprint(f\"✅ CV PIPELINE COMPLETE ({width}x{height})\")\n\nif gt_mask:\n    iou, acc = compute_metrics(final_mask, gt_mask, width, height)\n    print(f\"Pixel Accuracy: {acc*100:.2f}%\")\n    print(f\"IoU Score:      {iou:.4f}\")\nelse:\n    print(\"📊 Metrics: Upload a ground-truth mask to see Accuracy/IoU.\")\n\nprint(\"-\" * 40)\n\n# Save visual outputs\nsave_pixels_as_image(pixels, width, height, f\"{OUTPUT_DIR}/original.png\")\nres_pixels = [[(255*v, 255*v, 255*v) for v in row] for row in final_mask]\nsave_pixels_as_image(res_pixels, width, height, f\"{OUTPUT_DIR}/segmentation_result.png\")\nprint(f\"📁 Files saved in: /kaggle/working/{OUTPUT_DIR}/\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-17T16:12:44.981690Z","iopub.execute_input":"2026-04-17T16:12:44.982531Z","iopub.status.idle":"2026-04-17T16:12:45.234730Z","shell.execute_reply.started":"2026-04-17T16:12:44.982485Z","shell.execute_reply":"2026-04-17T16:12:45.233055Z"}},"outputs":[{"name":"stdout","text":"----------------------------------------\n✅ CV PIPELINE COMPLETE (320x240)\nPixel Accuracy: 99.91%\nIoU Score:      0.9908\n----------------------------------------\n📁 Files saved in: /kaggle/working/output/\n","output_type":"stream"}],"execution_count":26},{"cell